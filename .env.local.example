# Cesium Ion access token (optional but recommended).
#
# Without a token the app still runs using open imagery/terrain fallbacks
# (OpenStreetMap imagery + ellipsoid/flat terrain). With a free token from
# https://cesium.com/ion/tokens you unlock:
#   - Cesium World Terrain (photorealistic elevation)
#   - Cesium OSM Buildings (global 3D buildings)
#   - Bing / Sentinel imagery layers
#
# Copy this file to `.env.local` and fill in your token.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Version of CesiumJS to load from CDN.
NEXT_PUBLIC_CESIUM_VERSION=1.119

# Optional: self-host CesiumJS instead of loading from the CDN. Point this at a
# directory containing the Cesium build (Cesium.js, Workers/, Assets/,
# ThirdParty/, Widgets/). For example, copy node_modules/cesium/Build/Cesium
# into public/cesium and set:
#   NEXT_PUBLIC_CESIUM_BASE_URL=/cesium
NEXT_PUBLIC_CESIUM_BASE_URL=
